# Dictionary API (опционально)
# Получи ключи для расширенных функций перевода

# DeepL API (качественный перевод)
# https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Google Translate API
# https://cloud.google.com/translate
GOOGLE_TRANSLATE_API_KEY=

# Free Dictionary API (бесплатно, без ключа)
# https://dictionaryapi.dev/
# Не требует ключа

# Database
DATABASE_PATH=./data/linguflow.db
